{
  "name": "qiwiosity-mobile",
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "presync": "node ../database/sync-to-mobile.js",
    "start": "node scripts/clean-workspace-links.js && npm run presync && expo start",
    "expo-go": "node scripts/clean-workspace-links.js && expo start --go",
    "android": "npm run presync && expo start --android",
    "ios": "npm run presync && expo start --ios",
    "web": "npm run presync && expo start --web",
    "prebuild": "npm run presync && expo prebuild --clean",
    "pods": "cd ios && pod install"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "7",
    "@react-navigation/native": "7",
    "@react-navigation/native-stack": "7",
    "@supabase/supabase-js": "^2.49.0",
    "expo": "~54.0.0",
    "expo-audio": "~1.1.1",
    "expo-file-system": "~18.0.7",
    "expo-location": "~19.0.8",
    "expo-speech": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~12.0.5",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@expo/config-plugins": "~10.0.0",
    "@expo/ngrok": "^4.1.0"
  },
  "private": true
}
