<?xml version="1.0" encoding="utf-8"?>
<!--
  ic_qw_adventure — Adventure category.
  A mountain peak with an ascending zig-zag path and a flag at the top —
  "go somewhere, make it to the summit, tell the story."
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Mountain -->
    <path
        android:fillColor="#0B4F3C"
        android:pathData="M3,20 L12,4 L21,20 Z" />
    <!-- Snowcap -->
    <path
        android:fillColor="#FFF8EF"
        android:pathData="M9,10 L12,4 L15,10 L13.5,11 L12,9.5 L10.5,11 Z" />
    <!-- Ascending path -->
    <path
        android:fillColor="#C46B2E"
        android:pathData="M7.5,18 L10,14 L12,16 L14,12 L16.5,18 L15.5,18 L14,13.5 L12,17 L10,15 L8.5,18 Z" />
    <!-- Flag at the summit -->
    <path
        android:fillColor="#C46B2E"
        android:pathData="M12,4 L12,7 L14,6 L14,4.5 Z" />
</vector>
