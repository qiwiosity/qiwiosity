# Copy this file to .env and fill in. Never commit .env.

# ElevenLabs API key — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ── POI Reviews (AI Overview feature) ────────────────────────────────────────
# Google Cloud project key with Places API enabled — used to fetch real
# visitor reviews and ratings for each POI.
# Enable at: https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_PLACES_API_KEY=

# Anthropic API key — used to generate the AI overview from Google reviews.
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: override the default voice (ID or named alias from tts-render.js VOICES map).
# Defaults to "liam" — the Qiwiosity project narrator voice.
# Other British/Irish options: dave, daniel, fin, charlotte, lily.
# Or pass any raw voice ID from elevenlabs.io/app/voice-library.
# ELEVENLABS_VOICE=liam

# Optional: ElevenLabs model. "eleven_multilingual_v2" is the default.
# "eleven_turbo_v2_5" is faster/cheaper but slightly less natural.
# ELEVENLABS_MODEL=eleven_multilingual_v2
