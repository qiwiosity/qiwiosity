# ── Database ──────────────────────────────────────────────────────────────────
# Supabase connection string (Settings → Database → Connection string → URI)
# Use the "Transaction" or "Session" pooler URL for serverless/hosted envs
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Required for Snap & Identify (claude-haiku) and Deep-Dive narration (claude-sonnet)
# Get your key at: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── ElevenLabs ────────────────────────────────────────────────────────────────
# Required for server-side TTS proxy (Kiri, James, Aroha, Sam, Grace voices)
ELEVENLABS_API_KEY=...

# ── Admin ─────────────────────────────────────────────────────────────────────
# Secret key for the /admin moderation dashboard — keep this private
QW_ADMIN_KEY=change-me-to-a-long-random-string

# ── Supabase (server-side auth verification) ───────────────────────────────────
# Used by the Railway server to verify Supabase user JWTs on community write routes.
# SUPABASE_URL: auth/community project URL used by the Railway server
# SUPABASE_ANON_KEY: the public anon key — safe to use here, it's already in the app
SUPABASE_URL=https://osulujkdeuukilchfath.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Mobile public config. These are public anon keys; do not put service-role keys here.
EXPO_PUBLIC_AUTH_SUPABASE_URL=https://osulujkdeuukilchfath.supabase.co
EXPO_PUBLIC_AUTH_SUPABASE_ANON_KEY=eyJ...
EXPO_PUBLIC_CONTENT_SUPABASE_URL=https://hauksnqehzaxuoeaezji.supabase.co
EXPO_PUBLIC_CONTENT_SUPABASE_ANON_KEY=eyJ...
EXPO_PUBLIC_SERVER_API_BASE=https://qiwiosity-production.up.railway.app
EXPO_PUBLIC_CONTENT_API_BASE=https://api.qiwiosity.nz
